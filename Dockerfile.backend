FROM golang:1.25-alpine AS builder
WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o /jira-backend ./jira-backend/cmd

FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata
WORKDIR /app

COPY --from=builder /jira-backend .
COPY configs ./configs

RUN addgroup -S app \
    && adduser -S app -G app \
    && mkdir -p /app/logs \
    && chown -R app:app /app
USER app

EXPOSE 8000
CMD ["./jira-backend"]
